generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Profile {
  id           Int      @id @default(autoincrement())
  userName     String
  headline     String
  about        String   @db.Text
  profileImage String?  @db.LongText
  aboutImage   String?  @db.LongText
  githubUrl    String?
  linkedinUrl  String?
  twitterUrl   String?
  displayEmail String?
  whatsappNumber String?
  expYears     String?
  projectsDone String?
  happyClients String?
  updatedAt    DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  thumbnail   String?  @db.LongText
  techStack   String
  githubLink  String?
  liveLink    String?
  description String   @db.Text
  createdAt   DateTime @default(now())
}

model Experience {
  id           Int      @id @default(autoincrement())
  company      String
  role         String
  period       String
  startDate    String?
  endDate      String?
  isCurrent    Boolean  @default(false)
  logo         String?  @db.LongText
  achievements String   @db.Text
  createdAt    DateTime @default(now())
}

model Skill {
  id       Int    @id @default(autoincrement())
  category String
  name     String
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
